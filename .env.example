# API del backend Bun
NUXT_PUBLIC_API_BASE=http://localhost:3000/api

# Supabase (obtener en Supabase Dashboard → Settings → API)
NUXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NUXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Si no se configuran SUPABASE_URL y ANON_KEY, la app funciona en modo desarrollo
# con usuario por defecto (sin login requerido).
